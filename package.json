{
  "name": "interactive-lan-game",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build && npm run check:budget",
    "preview": "vite preview",
    "server": "node server/signalling-server.cjs",
    "server:watch": "node --watch server/signalling-server.cjs",
    "start": "npm run server",
    "start:all": "concurrently --kill-others --names \"SIGNAL,VITE\" --prefix-colors \"blue,green\" \"npm run server\" \"npm run dev\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "lint:strict": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "type-check": "tsc --noEmit",
    "validate": "npm run lint:strict && npm run type-check && npm run format:check",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "check:budget": "node scripts/check-performance-budget.cjs",
    "check:budget:ci": "npm run build && npm run check:budget",
    "analyze:bundle": "vite build && open dist/bundle-analysis/stats.html"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "peer": "^1.0.2",
    "peerjs": "^1.5.5",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-virtuoso": "^4.18.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "rollup-plugin-visualizer": "^5.12.0",
    "terser": "^5.46.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
